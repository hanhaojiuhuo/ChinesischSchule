# ─── Vercel Edge Config ─────────────────────────────────────────────────────
# Used to store admin credentials (fast, low-latency reads via SDK)
#
# 1. Create an Edge Config store in the Vercel dashboard
#    (Storage → Edge Config → Create)
# 2. Copy the connection string (starts with https://edge-config.vercel.com/…)
EDGE_CONFIG=https://edge-config.vercel.com/ecfg_XXXXXXXXXX?token=XXXXXXXXXX

# The Edge Config store ID (the "ecfg_…" part of the connection string, without the query string)
EDGE_CONFIG_ID=ecfg_XXXXXXXXXX

# A Vercel API token with permissions to write to Edge Config
# Create one at: https://vercel.com/account/tokens
VERCEL_API_TOKEN=XXXXXXXXXX

# ─── Vercel Blob ─────────────────────────────────────────────────────────────
# Used to store multilingual site-content overrides
#
# 1. Create a Blob store in the Vercel dashboard
#    (Storage → Blob → Create)
# 2. Copy the read-write token shown after creation
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_XXXXXXXXXX

# ─── Optional ────────────────────────────────────────────────────────────────
# Set to a sub-path if the site is not deployed at the root (e.g. /mysite)
# BASE_PATH=
