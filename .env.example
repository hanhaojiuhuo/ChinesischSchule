# ─── Vercel Edge Config (private – admin credentials) ────────────────────────
# Used to store admin credentials (fast, low-latency reads via SDK).
#
# On Vercel: EDGE_CONFIG is auto-set when the store is linked to the project.
# Locally:  set EDGE_CONFIG_ID + EDGE_CONFIG_TOKEN and the connection string
#           is constructed automatically.
#
# Option A – full connection string (auto-set by Vercel, or copy from dashboard):
# EDGE_CONFIG=https://edge-config.vercel.com/ecfg_XXXXXXXXXX?token=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
#
# Option B – individual pieces (simpler for .env.local):
EDGE_CONFIG_ID=ecfg_XXXXXXXXXX
EDGE_CONFIG_TOKEN=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ─── Vercel Blob (public – news, images, content) ───────────────────────────
# Used to store images, news content, and multilingual site-content overrides.
# The Blob store is public so visitors can load images/content directly.
#
# On Vercel: BLOB_READ_WRITE_TOKEN is auto-set when the store is linked.
# Locally:  copy the read-write token from the Vercel dashboard.
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_XXXXXXXXXX

# ─── Resend (password-reset emails) ──────────────────────────────────────────
# Required for the "Forgot password?" email flow on the admin login page.
#
# 1. Create a free account at https://resend.com
# 2. Generate an API key (API Keys → Create API Key)
# 3. Add and verify your sending domain in the Resend dashboard, then set
#    RESEND_FROM_EMAIL to an address on that domain.
#    While testing you may leave RESEND_FROM_EMAIL unset – it defaults to
#    Resend's shared sandbox address (onboarding@resend.dev).
RESEND_API_KEY=re_XXXXXXXXXX

# Optional: the "From" address used for password-reset emails.
# Must be on a domain verified in your Resend account.
# RESEND_FROM_EMAIL=noreply@yourdomain.com

# ─── Optional ────────────────────────────────────────────────────────────────
# Set to a sub-path if the site is not deployed at the root (e.g. /mysite)
# BASE_PATH=

# ─── Recovery mode ───────────────────────────────────────────────────────────
# When set to "true", the admin login accepts ANY password.
# Use this ONLY if you have forgotten all admin passwords.
# Steps:
#   1. Set RECOVERY_MODE=true and redeploy.
#   2. Log in at /admin with any username and password.
#   3. Create a new admin account from the admin panel.
#   4. Remove RECOVERY_MODE (or set it to "false") and redeploy again.
# RECOVERY_MODE=true
